generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum RoleName {
  SUPER_ADMIN
  ADMIN
  MR
  SALES_PERSON
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum VisitType {
  DOCTOR
  CHEMIST
}

enum VisitStatus {
  COMPLETED
  CANCELLED
  PENDING
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum BillStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMode {
  CASH
  CHEQUE
  UPI
  NEFT
  BANK_TRANSFER
}

enum SettlementType {
  GOODS_RETURN
  CREDIT_NOTE
  DISCOUNT
}

// ─── Auth & Users ─────────────────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement())
  name        RoleName @unique
  description String?
  users       User[]

  @@map("roles")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String    @unique
  passwordHash  String    @map("password_hash")
  roleId        Int       @map("role_id")
  role          Role      @relation(fields: [roleId], references: [id])
  employeeCode  String?   @unique @map("employee_code")
  profilePhoto  String?   @map("profile_photo")
  dateOfJoining DateTime? @map("date_of_joining") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  createdById   String?   @map("created_by")
  createdBy     User?     @relation("CreatedByUser", fields: [createdById], references: [id])
  createdUsers  User[]    @relation("CreatedByUser")

  refreshTokens       RefreshToken[]
  employeeTerritories EmployeeTerritory[]
  attendance          Attendance[]
  visits              Visit[]
  dailyReports        DailyReport[]
  doctorsAdded        Doctor[]
  chemistsAdded       Chemist[]
  ordersCreated       Order[]    @relation("OrderCreatedBy")
  ordersDelivered     Order[]    @relation("OrderDeliveredBy")
  billsCreated        Bill[]     @relation("BillCreatedBy")
  paymentsCollected   Payment[]  @relation("PaymentCollectedBy")
  settlementsCreated  Settlement[] @relation("SettlementCreatedBy")
  billImagesUploaded    BillImage[]    @relation("BillImageUploadedBy")
  visitImagesUploaded   VisitImage[]   @relation("VisitImageUploadedBy")
  doctorImagesUploaded  DoctorImage[]  @relation("DoctorImageUploadedBy")
  chemistImagesUploaded ChemistImage[] @relation("ChemistImageUploadedBy")
  assignedChemists    SalesPersonChemist[] @relation("SalesPersonAssignments")
  assignedToSalesPerson SalesPersonChemist[] @relation("ChemistAssignedBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

// ─── Territory Hierarchy ──────────────────────────────────────────────────────

model State {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  code      String     @unique
  districts District[]
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("states")
}

model District {
  id        Int      @id @default(autoincrement())
  name      String
  stateId   Int      @map("state_id")
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  cities    City[]
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([name, stateId])
  @@map("districts")
}

model City {
  id          Int         @id @default(autoincrement())
  name        String
  districtId  Int         @map("district_id")
  district    District    @relation(fields: [districtId], references: [id], onDelete: Cascade)
  territories Territory[]
  createdAt   DateTime    @default(now()) @map("created_at")

  @@unique([name, districtId])
  @@map("cities")
}

model Territory {
  id          Int     @id @default(autoincrement())
  name        String
  code        String? @unique
  cityId      Int     @map("city_id")
  city        City    @relation(fields: [cityId], references: [id], onDelete: Cascade)
  description String?
  isActive    Boolean @default(true) @map("is_active")

  employeeTerritories EmployeeTerritory[]
  doctors             Doctor[]
  chemists            Chemist[]
  visits              Visit[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("territories")
}

model EmployeeTerritory {
  id           Int       @id @default(autoincrement())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  territoryId  Int       @map("territory_id")
  territory    Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedById String?   @map("assigned_by")

  @@unique([userId, territoryId])
  @@map("employee_territories")
}

// ─── Doctors & Chemists ───────────────────────────────────────────────────────

model Doctor {
  id                  String       @id @default(uuid())
  name                String
  specialization      String?
  clinicName          String?      @map("clinic_name")
  hospitalName        String?      @map("hospital_name")
  phone               String?
  alternatePhone      String?      @map("alternate_phone")
  email               String?
  address             String?
  territoryId         Int?         @map("territory_id")
  territory           Territory?   @relation(fields: [territoryId], references: [id])
  addedById           String?      @map("added_by")
  addedBy             User?        @relation(fields: [addedById], references: [id])
  isActive            Boolean      @default(true) @map("is_active")
  latitude            Decimal?     @db.Decimal(10, 7)
  longitude           Decimal?     @db.Decimal(10, 7)
  locationCapturedAt  DateTime?    @map("location_captured_at")
  visits              Visit[]
  images              DoctorImage[]
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@map("doctors")
}

model Chemist {
  id                  String       @id @default(uuid())
  shopName            String       @map("shop_name")
  ownerName           String       @map("owner_name")
  phone               String
  alternatePhone      String?      @map("alternate_phone")
  email               String?
  gstNumber           String?      @map("gst_number")
  address             String?
  territoryId         Int?         @map("territory_id")
  territory           Territory?   @relation(fields: [territoryId], references: [id])
  addedById           String?      @map("added_by")
  addedBy             User?        @relation(fields: [addedById], references: [id])
  isActive            Boolean      @default(true) @map("is_active")
  latitude            Decimal?     @db.Decimal(10, 7)
  longitude           Decimal?     @db.Decimal(10, 7)
  locationCapturedAt  DateTime?    @map("location_captured_at")
  visits              Visit[]
  orders              Order[]
  bills               Bill[]
  salesPersons        SalesPersonChemist[]
  images              ChemistImage[]
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@map("chemists")
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model Attendance {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime         @db.Date
  checkInTime     DateTime?        @map("check_in_time")
  checkInLat      Decimal?         @map("check_in_lat") @db.Decimal(10, 7)
  checkInLng      Decimal?         @map("check_in_lng") @db.Decimal(10, 7)
  checkInAddress  String?          @map("check_in_address")
  checkOutTime    DateTime?        @map("check_out_time")
  checkOutLat     Decimal?         @map("check_out_lat") @db.Decimal(10, 7)
  checkOutLng     Decimal?         @map("check_out_lng") @db.Decimal(10, 7)
  checkOutAddress String?          @map("check_out_address")
  workingHours    Decimal?         @map("working_hours") @db.Decimal(5, 2)
  status          AttendanceStatus @default(PRESENT)
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@map("attendance")
}

// ─── Visits ───────────────────────────────────────────────────────────────────

model Visit {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  user            User        @relation(fields: [userId], references: [id])
  visitType       VisitType   @map("visit_type")
  doctorId        String?     @map("doctor_id")
  doctor          Doctor?     @relation(fields: [doctorId], references: [id])
  chemistId       String?     @map("chemist_id")
  chemist         Chemist?    @relation(fields: [chemistId], references: [id])
  territoryId     Int?        @map("territory_id")
  territory       Territory?  @relation(fields: [territoryId], references: [id])
  visitDate       DateTime    @map("visit_date") @db.Date
  visitTime       DateTime    @map("visit_time")
  lat             Decimal?    @db.Decimal(10, 7)
  lng             Decimal?    @db.Decimal(10, 7)
  locationAddress String?     @map("location_address")
  purpose         String?
  notes           String?
  followUpDate    DateTime?   @map("follow_up_date") @db.Date
  followUpNotes   String?     @map("follow_up_notes")
  followUpDone        Boolean     @default(false) @map("follow_up_done")
  status              VisitStatus @default(COMPLETED)
  locationCapturedAt  DateTime?   @map("location_captured_at")
  products            VisitProduct[]
  images              VisitImage[]
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  @@map("visits")
}

model VisitProduct {
  id          Int      @id @default(autoincrement())
  visitId     String   @map("visit_id")
  visit       Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  productName String   @map("product_name")
  details     String?
  quantity    String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("visit_products")
}

// ─── Daily Working Reports ────────────────────────────────────────────────────

model DailyReport {
  id                 String       @id @default(uuid())
  userId             String       @map("user_id")
  user               User         @relation(fields: [userId], references: [id])
  date               DateTime     @db.Date
  totalVisits        Int          @default(0) @map("total_visits")
  doctorVisits       Int          @default(0) @map("doctor_visits")
  chemistVisits      Int          @default(0) @map("chemist_visits")
  productsDiscussed  String?      @map("products_discussed")
  competitorActivity String?      @map("competitor_activity")
  highlights         String?
  challenges         String?
  remarks            String?
  status             ReportStatus @default(DRAFT)
  submittedAt        DateTime?    @map("submitted_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@map("daily_reports")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id               String      @id @default(uuid())
  orderNumber      String      @unique @map("order_number")
  chemistId        String      @map("chemist_id")
  chemist          Chemist     @relation(fields: [chemistId], references: [id])
  status           OrderStatus @default(PENDING)
  totalAmount      Decimal     @map("total_amount") @db.Decimal(12, 2)
  orderDate        DateTime    @default(now()) @map("order_date")
  expectedDelivery DateTime?   @map("expected_delivery") @db.Date
  deliveredAt      DateTime?   @map("delivered_at")
  deliveredById    String?     @map("delivered_by")
  deliveredBy      User?       @relation("OrderDeliveredBy", fields: [deliveredById], references: [id])
  notes            String?
  createdById      String      @map("created_by")
  createdBy        User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  items            OrderItem[]
  bills            Bill[]
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     String  @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productName String  @map("product_name")
  quantity    Int
  rate        Decimal @db.Decimal(10, 2)
  amount      Decimal @db.Decimal(12, 2)
  notes       String?

  @@map("order_items")
}

// ─── Bills ────────────────────────────────────────────────────────────────────

model Bill {
  id          String     @id @default(uuid())
  billNumber  String     @unique @map("bill_number")
  chemistId   String     @map("chemist_id")
  chemist     Chemist    @relation(fields: [chemistId], references: [id])
  orderId     String?    @map("order_id")
  order       Order?     @relation(fields: [orderId], references: [id])
  totalAmount Decimal    @map("total_amount") @db.Decimal(12, 2)
  paidAmount  Decimal    @default(0) @map("paid_amount") @db.Decimal(12, 2)
  dueAmount   Decimal    @map("due_amount") @db.Decimal(12, 2)
  dueDate     DateTime?  @map("due_date") @db.Date
  status      BillStatus @default(UNPAID)
  notes        String?
  createdById  String     @map("created_by")
  createdBy    User       @relation("BillCreatedBy", fields: [createdById], references: [id])
  payments     Payment[]
  settlements  Settlement[]
  images       BillImage[]
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("bills")
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id              String      @id @default(uuid())
  billId          String      @map("bill_id")
  bill            Bill        @relation(fields: [billId], references: [id])
  amount          Decimal     @db.Decimal(12, 2)
  paymentMode     PaymentMode @map("payment_mode")
  referenceNumber String?     @map("reference_number")
  collectedById   String      @map("collected_by")
  collectedBy     User        @relation("PaymentCollectedBy", fields: [collectedById], references: [id])
  collectedAt     DateTime    @default(now()) @map("collected_at")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")

  @@map("payments")
}

// ─── Settlements ──────────────────────────────────────────────────────────────

model Settlement {
  id          String         @id @default(uuid())
  billId      String         @map("bill_id")
  bill        Bill           @relation(fields: [billId], references: [id])
  type        SettlementType
  amount      Decimal        @db.Decimal(12, 2)
  reason      String?
  createdById String         @map("created_by")
  createdBy   User           @relation("SettlementCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime       @default(now()) @map("created_at")

  @@map("settlements")
}

// ─── Sales Person ↔ Chemist Assignment ───────────────────────────────────────

model SalesPersonChemist {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  user         User     @relation("SalesPersonAssignments", fields: [userId], references: [id], onDelete: Cascade)
  chemistId    String   @map("chemist_id")
  chemist      Chemist  @relation(fields: [chemistId], references: [id], onDelete: Cascade)
  assignedById String?  @map("assigned_by")
  assignedBy   User?    @relation("ChemistAssignedBy", fields: [assignedById], references: [id])
  assignedAt   DateTime @default(now()) @map("assigned_at")

  @@unique([userId, chemistId])
  @@map("sales_person_chemists")
}

// ─── Bill Images ──────────────────────────────────────────────────────────────

model BillImage {
  id           Int      @id @default(autoincrement())
  billId       String   @map("bill_id")
  bill         Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  url          String
  filename     String
  uploadedById String   @map("uploaded_by")
  uploadedBy   User     @relation("BillImageUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("bill_images")
}

model VisitImage {
  id           Int      @id @default(autoincrement())
  visitId      String   @map("visit_id")
  visit        Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  url          String
  filename     String
  uploadedById String   @map("uploaded_by")
  uploadedBy   User     @relation("VisitImageUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("visit_images")
}

model DoctorImage {
  id           Int      @id @default(autoincrement())
  doctorId     String   @map("doctor_id")
  doctor       Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  url          String
  filename     String
  uploadedById String   @map("uploaded_by")
  uploadedBy   User     @relation("DoctorImageUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("doctor_images")
}

model ChemistImage {
  id           Int      @id @default(autoincrement())
  chemistId    String   @map("chemist_id")
  chemist      Chemist  @relation(fields: [chemistId], references: [id], onDelete: Cascade)
  url          String
  filename     String
  uploadedById String   @map("uploaded_by")
  uploadedBy   User     @relation("ChemistImageUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("chemist_images")
}
